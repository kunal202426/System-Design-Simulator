{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "cd frontend && npm ci",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL (e.g., https://your-app.onrender.com)",
      "required": true
    },
    "VITE_WS_URL": {
      "description": "Backend WebSocket URL (e.g., wss://your-app.onrender.com)",
      "required": true
    }
  }
}
